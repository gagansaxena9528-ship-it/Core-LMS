{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for authentication and role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] },
        "joined": { "type": "string", "format": "date-time" },
        "av": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Detailed student information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "courseId": { "type": "string" },
        "batchId": { "type": "string" },
        "teacherId": { "type": "string" },
        "progress": { "type": "number" },
        "fee": { "type": "number" },
        "paid": { "type": "number" }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Detailed teacher information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "bio": { "type": "string" },
        "rating": { "type": "number" },
        "coursesCount": { "type": "number" },
        "batchesCount": { "type": "number" },
        "studentsCount": { "type": "number" }
      }
    },
    "Course": {
      "title": "Course",
      "description": "Course details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "teacherId": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "level": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "status": { "type": "string", "enum": ["Active", "Draft"] },
        "emoji": { "type": "string" },
        "description": { "type": "string" },
        "keyPoints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Module": {
      "title": "Module",
      "description": "Module within a course.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A single lesson (video, pdf, etc.) within a module.",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "pdf", "text", "file"] },
        "content": { "type": "string" },
        "videoUrl": { "type": "string" },
        "videoType": { "type": "string", "enum": ["youtube", "direct"] },
        "fileUrl": { "type": "string" },
        "duration": { "type": "string" },
        "order": { "type": "number" },
        "isFree": { "type": "boolean" },
        "dripDays": { "type": "number" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "status": { "type": "string", "enum": ["Published", "Draft", "Scheduled"] },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "accessControl": {
          "type": "object",
          "properties": {
            "batchIds": { "type": "array", "items": { "type": "string" } },
            "isPaidOnly": { "type": "boolean" }
          }
        },
        "analytics": {
          "type": "object",
          "properties": {
            "views": { "type": "number" },
            "avgWatchTime": { "type": "number" },
            "downloads": { "type": "number" }
          }
        }
      }
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Assignment details.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "batchId": { "type": "string" },
        "moduleId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "totalMarks": { "type": "number" },
        "fileUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Completed"] }
      }
    },
    "AssignmentSubmission": {
      "title": "AssignmentSubmission",
      "description": "Student submission for an assignment.",
      "type": "object",
      "properties": {
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "submissionDate": { "type": "string", "format": "date-time" },
        "fileUrl": { "type": "string" },
        "marks": { "type": "number" },
        "feedback": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Checked", "Pending"] }
      }
    },
    "Result": {
      "title": "Result",
      "description": "Result of an exam attempt.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "score": { "type": "number" },
        "totalMarks": { "type": "number" },
        "percentage": { "type": "number" },
        "status": { "type": "string", "enum": ["Pass", "Fail"] },
        "date": { "type": "string", "format": "date-time" },
        "answers": { "type": "object" },
        "feedback": { "type": "object" },
        "manualMarks": { "type": "object" }
      }
    },
    "Exam": {
      "title": "Exam",
      "description": "Exam or quiz details.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "batchId": { "type": "string" },
        "moduleId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructions": { "type": "string" },
        "duration": { "type": "number" },
        "totalMarks": { "type": "number" },
        "passingMarks": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Draft", "Completed"] },
        "type": { "type": "string", "enum": ["Practice", "Final"] },
        "autoResult": { "type": "boolean" },
        "attemptsAllowed": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "negativeMarking": { "type": "number" }
      }
    },
    "Question": {
      "title": "Question",
      "description": "Objective or descriptive question for an exam.",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "question": { "type": "string" },
        "type": { "type": "string", "enum": ["MCQ", "Multiple", "TrueFalse", "Descriptive"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "answerIndex": { "type": "number" },
        "correctOptions": { "type": "array", "items": { "type": "number" } },
        "correctAnswer": { "type": "string" },
        "marks": { "type": "number" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "subject": { "type": "string" }
      }
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "batchId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent"] }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Fee payment record.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "courseId": { "type": "string" },
        "total": { "type": "number" },
        "paid": { "type": "number" },
        "pending": { "type": "number" },
        "mode": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Paid", "Partial", "Pending"] }
      }
    },
    "LiveClass": {
      "title": "LiveClass",
      "description": "Scheduled live session.",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "batchId": { "type": "string" },
        "teacherId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["Live", "Upcoming", "Completed"] },
        "zoomLink": { "type": "string" },
        "zoomPassword": { "type": "string" },
        "meetLink": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/students/{userId}": { "schema": "Student", "description": "Student specific data" },
    "/teachers/{userId}": { "schema": "Teacher", "description": "Teacher specific data" },
    "/courses/{courseId}": { "schema": "Course", "description": "Course information" },
    "/courses/{courseId}/modules/{moduleId}": { "schema": "Module", "description": "Modules within a course" },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "Lessons (videos, pdfs, etc.)" },
    "/assignments/{assignmentId}": { "schema": "Assignment", "description": "Assignments" },
    "/submissions/{submissionId}": { "schema": "AssignmentSubmission", "description": "Assignment submissions" },
    "/results/{resultId}": { "schema": "Result", "description": "Exam results" },
    "/exams/{examId}": { "schema": "Exam", "description": "Exams" },
    "/exams/{examId}/questions/{questionId}": { "schema": "Question", "description": "Questions for an exam" },
    "/attendance/{attendanceId}": { "schema": "Attendance", "description": "Attendance records" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records" },
    "/liveClasses/{classId}": { "schema": "LiveClass", "description": "Live class sessions" }
  }
}
